      <w:document xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:cx="http://schemas.microsoft.com/office/drawing/2014/chartex" xmlns:cx1="http://schemas.microsoft.com/office/drawing/2015/9/8/chartex" xmlns:cx2="http://schemas.microsoft.com/office/drawing/2015/10/21/chartex" xmlns:cx3="http://schemas.microsoft.com/office/drawing/2016/5/9/chartex" xmlns:cx4="http://schemas.microsoft.com/office/drawing/2016/7/11/chartex" xmlns:cx5="http://schemas.microsoft.com/office/drawing/2016/8/17/chartex" xmlns:cx6="http://schemas.microsoft.com/office/drawing/2017/9/26/chartex" xmlns:cx7="http://schemas.microsoft.com/office/drawing/2017/10/30/chartex" xmlns:cx8="http://schemas.microsoft.com/office/drawing/2018/5/23/chartex" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:aink="http://schemas.microsoft.com/office/drawing/2016/ink" xmlns:am3d="http://schemas.microsoft.com/office/drawing/2017/model3d" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:w15="http://schemas.microsoft.com/office/word/2012/wordml" xmlns:w16cex="http://schemas.microsoft.com/office/word/2018/wordml/cex" xmlns:w16cid="http://schemas.microsoft.com/office/word/2016/wordml/cid" xmlns:w16="http://schemas.microsoft.com/office/word/2018/wordml" xmlns:w16sdtdh="http://schemas.microsoft.com/office/word/2020/wordml/sdtdatahash" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh wp14">
        <w:body>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Title"/>
            </w:pPr>
            <w:r>
              <w:t>O‘ZBEKISTON RESPUBLIKASI PROKURATURA ORGANLARIDA YOSHLAR BILAN ISHLASH, ULARNING KASBIY MAHORATINI OSHIRISH, MA’NAVIYATINI YUKSALTIRISH VA BO‘SH VAQTINI MAZMUNLI TASHKIL ETISHGA DOIR</w:t>
            </w:r>
            <w:bookmarkStart w:id="0" w:name="_GoBack"/>
            <w:bookmarkEnd w:id="0"/>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Subtitle"/>
            </w:pPr>
            <w:r>
              <w:t>CHORA-TADBIRLAR REJASI</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Heading1"/>
            </w:pPr>
            <w:r>
              <w:t>1. YOSH XODIMLARNING PROFESSIONAL KASB-MAHORATINI OSHIRISH, ISTIQBOLLI YOSH RAHBAR KADRLARNI TAYYORLASH VA RIVOJLANTIRISH</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Heading2"/>
            </w:pPr>
            <w:r>
              <w:t>1.1. Birinchi marta prokuratura organlariga xizmatga qabul qilinayotgan shaxslarning qasamyod qabul qilish tadbirlarini yuqori saviyada o‘tkazib borish</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Birinchi marta xizmatga qabul qilinayotgan shaxslarning qasamyod qabul qilish tadbirini o‘tkazish.</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>OAV hamda ijtimoiy tarmoqlar orqali keng yoritish (Doimiy).</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Heading2"/>
            </w:pPr>
            <w:r>
              <w:t>1.2. Yosh xodimlarning kasbiy ko‘nikmalarini rivojlantirish va faoliyat samaradorligini oshirish choralarini ko‘rish</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>"Tajriba maktabi" va "ustoz-shogird" an’analarini takomillashtirish orqali yosh xodimlarni tarbiyalash, ularga tajribali xodimlardan murabbiy biriktirish hamda rag‘batlantirish amaliyotini yo‘lga qo‘yish.</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>OAV hamda ijtimoiy tarmoqlar orqali keng yoritish (Doimiy).</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Heading2"/>
            </w:pPr>
            <w:r>
              <w:t>1.3. Xodimlarga qonunchilik hujjatlari, shu jumladan, yangi qabul qilinayotgan qonunlar va boshqa normativ-huquqiy hujjatlarning mazmun-mohiyatini yetkazish hamda ularni faoliyatda tatbiq etish ko‘nikmalarini shakllantirib borish</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Prokuratura organlariga ilk xizmatga qabul qilingan yosh xodimlarni O‘zbekiston Respublikasi Huquqni muhofaza qilish Akademiyasida reja asosida o‘qitish.</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Xodimlarni tashkil etilgan masofaviy va elektiv kurslarda muntazam malaka oshirishlarini ta’minlash orqali kasbiy ko‘nikmalarini rivojlantirib borish.</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Masofaviy va elektiv kurslarda yuqori natijalarga erishgan g‘oliblarni munosib taqdirlash (Doimiy).</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Heading2"/>
            </w:pPr>
            <w:r>
              <w:t>1.4. Oliy yuridik ta’lim tashkilotlari talabalarini prokuratura organlarida ish o‘rganishlarini tashkil etish</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Oliy yuridik ta’lim muassasalarida o‘qiyotgan talabalar hududlar kesimida shakllantirilib, ularning ish o‘rganishlarini tashkil qilish (2026-yil iyun-avgust).</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Heading1"/>
            </w:pPr>
            <w:r>
              <w:t>2. YOSHLAR MA’NAVIYATINI YUKSALTIRISH, BO‘SH VAQTINI MAZMUNLI TASHKIL ETISH VA MA’RIFIY TARG‘IBOTNING SAMARALI USULLARINI TATBIQ ETISH</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Heading2"/>
            </w:pPr>
            <w:r>
              <w:t>2.1. Yosh xodimlarda xizmatga sadoqat, fidoyilik, halollik kabi xislatlarni kuchaytirish maqsadida prokuratura faxriylari bilan uchrashuvlarni tashkil etish</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Prokuratura faxriylarini ijtimoiy qo‘llab-quvvatlash markazi va Bosh prokuratura huzuridagi jamoatchilik kengashi bilan hamkorlikda xodimlar va faxriylar o‘rtasida "Uch avlod uchrashuvlari"ni o‘tkazish.</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Mazkur tadbirni alohida reja asosida barcha hududlarda tashkil etish.</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>OAV hamda ijtimoiy tarmoqlar orqali keng yoritish (Doimiy).</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Heading2"/>
            </w:pPr>
            <w:r>
              <w:t>2.2. 30-iyun – "Yoshlar kuni" munosabati bilan "Prokuror va yoshlar" uchrashuvlarini tashkil etish</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Bosh prokuraturaning tegishli tarmoqlari tomonidan tadbir dasturini ishlab chiqish va ishtirokchilar ro‘yxatini shakllantirish.</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Tadbirni Yoshlar ishlari agentligi bilan hamkorlikda yuqori saviyada tashkil etilishini ta’minlash.</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>OAV hamda ijtimoiy tarmoqlar orqali keng yoritish (2026-yil iyun-iyul).</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Heading2"/>
            </w:pPr>
            <w:r>
              <w:t>2.3. Xodimlar o‘rtasida kitobxonlikni keng ommalashtirish</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Bosh prokuraturaning "Elektron hujjat aylanishi" axborot tizimidagi elektron kutubxonani milliy va jahon adabiyoti, shu jumladan yuridik, ilmiy-tarixiy va badiiy asarlar bilan to‘ldirib borish (Doimiy).</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Heading2"/>
            </w:pPr>
            <w:r>
              <w:t>2.4. Prokuratura organlarida kitoblar ko‘rgazmasi va savdolarini tashkil qilish</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Bosh prokuratura hamda viloyat prokuraturalari va ularga tenglashtirilgan prokuraturalarda reja-jadval asosida kitoblar ko‘rgazmasi hamda savdolarini o‘tkazish (2026-yil may-iyul).</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Heading2"/>
            </w:pPr>
            <w:r>
              <w:t>2.5. Xodimlar o‘rtasida sportni ommalashtirish, ularning jismoniy faolligini oshirishga qaratilgan chora-tadbirlarni amalga oshirish</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Xodimlar o‘rtasida sportning suzish, mini futbol, tennis, stol tennisi, shashka, shaxmat kabi turlari bo‘yicha musobaqalar tashkil etish.</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Kurash bo‘yicha "Prokuratura polvoni" turnirini o‘tkazish.</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Turnir va musobaqalar g‘oliblarini munosib taqdirlash.</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>OAV hamda ijtimoiy tarmoqlar orqali keng yoritish (Doimiy).</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="Heading2"/>
            </w:pPr>
            <w:r>
              <w:t>2.6. Xodimlarning madaniy-estetik hordiq chiqarishlari uchun ommaviy-madaniy tadbirlarni tashkil etish</w:t>
            </w:r>
          </w:p>
          <w:p w:rsidR="00A17A1A" w:rsidRDefault="00A17A1A">
            <w:pPr>
              <w:pStyle w:val="ListParagraph"/>
              <w:numPr>
                <w:ilvl w:val="0"/>
                <w:numId w:val="1"/>
              </w:numPr>
            </w:pPr>
            <w:r>
              <w:t>Xodimlarni reja-jadval asosida kutubxonalar, muzeylar, teatrlar, Islom sivilizatsiyasi markazi va shu kabi boshqa ijtimoiy-ma’naviy maskanlarga jalb etish.</w:t>
            </w:r>
          </w:p>
